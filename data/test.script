CREATE USER SA PASSWORD DIGEST 'd41d8cd98f00b204e9800998ecf8427e'
ALTER USER SA SET LOCAL TRUE
CREATE SCHEMA PUBLIC AUTHORIZATION DBA
CREATE MEMORY TABLE PUBLIC.ADMINISTRATORS(ID BIGINT NOT NULL PRIMARY KEY,ACCESS_LEVEL VARCHAR(50),DEPARTMENT VARCHAR(100))
CREATE MEMORY TABLE PUBLIC.CATEGORIES(ID BIGINT GENERATED BY DEFAULT AS IDENTITY(START WITH 1) NOT NULL PRIMARY KEY,NAME VARCHAR(100) NOT NULL,DESCRIPTION VARCHAR(500),UNIQUE(NAME))
ALTER TABLE PUBLIC.CATEGORIES ALTER COLUMN ID RESTART WITH 5
CREATE MEMORY TABLE PUBLIC.CLIENTS(LOYALTY_POINTS INTEGER,ID BIGINT NOT NULL PRIMARY KEY,PHONE VARCHAR(20))
CREATE MEMORY TABLE PUBLIC.EVENT_CATEGORY(CATEGORY_ID BIGINT NOT NULL,EVENT_ID BIGINT NOT NULL,CONSTRAINT FK97XS10D9TVHFW8UP2KPPG0HPD FOREIGN KEY(CATEGORY_ID) REFERENCES PUBLIC.CATEGORIES(ID))
CREATE MEMORY TABLE PUBLIC.EVENTS(AVAILABLE_TICKETS INTEGER NOT NULL,BASE_PRICE DOUBLE NOT NULL,END_TIME TIME(6),EVENT_DATE DATE NOT NULL,START_TIME TIME(6) NOT NULL,TOTAL_TICKETS INTEGER NOT NULL,CREATED_AT TIMESTAMP NOT NULL,ID BIGINT GENERATED BY DEFAULT AS IDENTITY(START WITH 1) NOT NULL PRIMARY KEY,ORGANIZER_ID BIGINT NOT NULL,VENUE_ID BIGINT NOT NULL,STATUS VARCHAR(20) NOT NULL,TITLE VARCHAR(200) NOT NULL,DESCRIPTION VARCHAR(2000),CHECK((PUBLIC.EVENTS.STATUS) IN (('DRAFT'),('PUBLISHED'),('CANCELLED'),('COMPLETED'))))
ALTER TABLE PUBLIC.EVENTS ALTER COLUMN ID RESTART WITH 4
CREATE MEMORY TABLE PUBLIC.ORDERS(TOTAL_AMOUNT DOUBLE NOT NULL,CLIENT_ID BIGINT NOT NULL,ID BIGINT GENERATED BY DEFAULT AS IDENTITY(START WITH 1) NOT NULL PRIMARY KEY,ORDER_DATE TIMESTAMP NOT NULL,PAYMENT_ID BIGINT,STATUS VARCHAR(20) NOT NULL,ORDER_NUMBER VARCHAR(50) NOT NULL,UNIQUE(PAYMENT_ID),CHECK((PUBLIC.ORDERS.STATUS) IN (('PENDING'),('CONFIRMED'),('CANCELLED'),('REFUNDED'))),UNIQUE(ORDER_NUMBER),CONSTRAINT FKM2DEP9DERPOAEHSHBKKATAM3V FOREIGN KEY(CLIENT_ID) REFERENCES PUBLIC.CLIENTS(ID))
ALTER TABLE PUBLIC.ORDERS ALTER COLUMN ID RESTART WITH 13
CREATE MEMORY TABLE PUBLIC.ORGANIZERS(ID BIGINT NOT NULL PRIMARY KEY,SIRET VARCHAR(14),BANK_ACCOUNT VARCHAR(34),COMPANY_NAME VARCHAR(200),UNIQUE(SIRET))
CREATE MEMORY TABLE PUBLIC.PAYMENTS(AMOUNT DOUBLE NOT NULL,ID BIGINT GENERATED BY DEFAULT AS IDENTITY(START WITH 1) NOT NULL PRIMARY KEY,PAYMENT_DATE TIMESTAMP NOT NULL,METHOD VARCHAR(20) NOT NULL,STATUS VARCHAR(20) NOT NULL,TRANSACTION_ID VARCHAR(100),CHECK((PUBLIC.PAYMENTS.METHOD) IN (('CARD'),('PAYPAL'),('MOBILE_MONEY'))),CHECK((PUBLIC.PAYMENTS.STATUS) IN (('PENDING'),('COMPLETED'),('FAILED'),('REFUNDED'))),UNIQUE(TRANSACTION_ID))
ALTER TABLE PUBLIC.PAYMENTS ALTER COLUMN ID RESTART WITH 4
CREATE MEMORY TABLE PUBLIC.TICKETS(PRICE DOUBLE NOT NULL,EVENT_ID BIGINT NOT NULL,ID BIGINT GENERATED BY DEFAULT AS IDENTITY(START WITH 1) NOT NULL PRIMARY KEY,ISSUE_DATE TIMESTAMP NOT NULL,ORDER_ID BIGINT,STATUS VARCHAR(20) NOT NULL,TICKET_TYPE VARCHAR(20) NOT NULL,QR_CODE VARCHAR(100) NOT NULL,CHECK((PUBLIC.TICKETS.STATUS) IN (('AVAILABLE'),('RESERVED'),('SOLD'),('USED'),('CANCELLED'))),CHECK((PUBLIC.TICKETS.TICKET_TYPE) IN (('SIMPLE'),('PREMIUM'),('VIP'),('VVIP'))),UNIQUE(QR_CODE),CONSTRAINT FK3UTAFE14RUPAYPJOCLDJAJ4OL FOREIGN KEY(EVENT_ID) REFERENCES PUBLIC.EVENTS(ID),CONSTRAINT FKQGI3SBV1U45S41WAWH75UT8PH FOREIGN KEY(ORDER_ID) REFERENCES PUBLIC.ORDERS(ID))
ALTER TABLE PUBLIC.TICKETS ALTER COLUMN ID RESTART WITH 18
CREATE MEMORY TABLE PUBLIC.USERS(CREATED_AT TIMESTAMP NOT NULL,ID BIGINT GENERATED BY DEFAULT AS IDENTITY(START WITH 1) NOT NULL PRIMARY KEY,USER_TYPE VARCHAR(31) NOT NULL,FIRST_NAME VARCHAR(100) NOT NULL,LAST_NAME VARCHAR(100) NOT NULL,EMAIL VARCHAR(150) NOT NULL,PASSWORD VARCHAR(255) NOT NULL,UNIQUE(EMAIL))
ALTER TABLE PUBLIC.USERS ALTER COLUMN ID RESTART WITH 8
CREATE MEMORY TABLE PUBLIC.VENUES(CAPACITY INTEGER NOT NULL,ID BIGINT GENERATED BY DEFAULT AS IDENTITY(START WITH 1) NOT NULL PRIMARY KEY,CITY VARCHAR(100) NOT NULL,COUNTRY VARCHAR(100) NOT NULL,NAME VARCHAR(200) NOT NULL,ADDRESS VARCHAR(300) NOT NULL,DESCRIPTION VARCHAR(1000))
ALTER TABLE PUBLIC.VENUES ALTER COLUMN ID RESTART WITH 4
ALTER TABLE PUBLIC.ADMINISTRATORS ADD CONSTRAINT FK3W6WCFO04I0L5SFXGCF6IQ0YH FOREIGN KEY(ID) REFERENCES PUBLIC.USERS(ID)
ALTER TABLE PUBLIC.CLIENTS ADD CONSTRAINT FK1HGWDP9VL25XL9I7S354SIFEY FOREIGN KEY(ID) REFERENCES PUBLIC.USERS(ID)
ALTER TABLE PUBLIC.EVENT_CATEGORY ADD CONSTRAINT FKNDKV2AIXWQ4IBW0XBOXTFQKVO FOREIGN KEY(EVENT_ID) REFERENCES PUBLIC.EVENTS(ID)
ALTER TABLE PUBLIC.EVENTS ADD CONSTRAINT FKMIED7EL0KCL27UL1MN6384HKI FOREIGN KEY(ORGANIZER_ID) REFERENCES PUBLIC.ORGANIZERS(ID)
ALTER TABLE PUBLIC.EVENTS ADD CONSTRAINT FKQDXYGDERNWWT74HDVIX9U5NR3 FOREIGN KEY(VENUE_ID) REFERENCES PUBLIC.VENUES(ID)
ALTER TABLE PUBLIC.ORDERS ADD CONSTRAINT FK8AOL9F99S97MTYHIJ0TVFJ41F FOREIGN KEY(PAYMENT_ID) REFERENCES PUBLIC.PAYMENTS(ID)
ALTER TABLE PUBLIC.ORGANIZERS ADD CONSTRAINT FKKNFG9JNDM0R8MJI804I38Y1TB FOREIGN KEY(ID) REFERENCES PUBLIC.USERS(ID)
